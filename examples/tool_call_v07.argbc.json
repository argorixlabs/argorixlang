{
  "bytecode_version": "0.7",
  "language": "Argorix Lang",
  "module": "Argorix.Tools",
  "agents": [
    {"name":"ResearchAgent","approval":"granted"},
    {"name":"PolicyJudge","approval":"denied"},
    {"name":"RuntimeGate","approval":"granted"}
  ],
  "capabilities": [
    {"name":"web.search","level":"restricted","requires_approval":true},
    {"name":"policy.evaluate","level":"safe","requires_approval":false},
    {"name":"trace.write","level":"safe","requires_approval":false},
    {"name":"state.write","level":"safe","requires_approval":false},
    {"name":"runtime.guard","level":"safe","requires_approval":false},
    {"name":"runtime.halt","level":"restricted","requires_approval":true}
  ],
  "tools": [
    {"name":"WebSearch","capability":"web.search","input":"UserPrompt","output":"ToolResult"}
  ],
  "instructions": [
    {"op":"DeclareCapability","name":"web.search","level":"restricted","requires_approval":true},
    {"op":"DeclareCapability","name":"policy.evaluate","level":"safe","requires_approval":false},
    {"op":"DeclareCapability","name":"trace.write","level":"safe","requires_approval":false},
    {"op":"DeclareCapability","name":"state.write","level":"safe","requires_approval":false},
    {"op":"DeclareCapability","name":"runtime.guard","level":"safe","requires_approval":false},
    {"op":"DeclareCapability","name":"runtime.halt","level":"restricted","requires_approval":true},
    {"op":"DeclareTool","name":"WebSearch","capability":"web.search","input":"UserPrompt","output":"ToolResult"},
    {"op":"DeclareAgent","name":"ResearchAgent","approval":"granted"},
    {"op":"RequireCapability","agent":"ResearchAgent","capability":"web.search"},
    {"op":"RequireApproval","agent":"ResearchAgent","capability":"web.search"},
    {"op":"RequireCapability","agent":"ResearchAgent","capability":"state.write"},
    {"op":"RequireCapability","agent":"ResearchAgent","capability":"runtime.guard"},
    {"op":"AuthorizeTool","agent":"ResearchAgent","tool":"WebSearch"},
    {"op":"DeclareHandler","agent":"ResearchAgent","message_type":"UserPrompt","binding":"prompt"},
    {"op":"InvokeIntrinsic","agent":"ResearchAgent","name":"marron","argument":"prompt"},
    {"op":"InvokeIntrinsic","agent":"ResearchAgent","name":"facu","argument":"prompt"},
    {"op":"CallTool","agent":"ResearchAgent","tool":"WebSearch","binding":"prompt"},
    {"op":"EmitMessage","agent":"ResearchAgent","message_type":"ToolResult","to":"PolicyJudge"},
    {"op":"EndHandler"},
    {"op":"DeclareAgent","name":"PolicyJudge","approval":"denied"},
    {"op":"RequireCapability","agent":"PolicyJudge","capability":"policy.evaluate"},
    {"op":"RequireCapability","agent":"PolicyJudge","capability":"state.write"},
    {"op":"RequireCapability","agent":"PolicyJudge","capability":"runtime.guard"},
    {"op":"DeclareHandler","agent":"PolicyJudge","message_type":"ToolResult","binding":"result"},
    {"op":"InvokeIntrinsic","agent":"PolicyJudge","name":"marron","argument":"result"},
    {"op":"InvokeIntrinsic","agent":"PolicyJudge","name":"facu","argument":"result"},
    {"op":"EmitMessage","agent":"PolicyJudge","message_type":"Decision","to":"RuntimeGate"},
    {"op":"EndHandler"},
    {"op":"DeclareAgent","name":"RuntimeGate","approval":"granted"},
    {"op":"RequireCapability","agent":"RuntimeGate","capability":"trace.write"},
    {"op":"RequireCapability","agent":"RuntimeGate","capability":"runtime.halt"},
    {"op":"RequireApproval","agent":"RuntimeGate","capability":"runtime.halt"},
    {"op":"RequireCapability","agent":"RuntimeGate","capability":"runtime.guard"},
    {"op":"RequireCapability","agent":"RuntimeGate","capability":"state.write"},
    {"op":"DeclareHandler","agent":"RuntimeGate","message_type":"Decision","binding":"decision"},
    {"op":"InvokeIntrinsic","agent":"RuntimeGate","name":"marron","argument":"decision"},
    {"op":"InvokeIntrinsic","agent":"RuntimeGate","name":"facu","argument":"decision"},
    {"op":"TraceValue","agent":"RuntimeGate","binding":"decision"},
    {"op":"HandlerHalt","agent":"RuntimeGate"},
    {"op":"EndHandler"},
    {"op":"DeclareProtocol","name":"ToolDefense"},
    {"op":"SendMessage","from":"User","to":"ResearchAgent","act":"tell","message_type":"UserPrompt"},
    {"op":"SendMessage","from":"ResearchAgent","to":"PolicyJudge","act":"propose","message_type":"ToolResult"},
    {"op":"SendMessage","from":"PolicyJudge","to":"RuntimeGate","act":"commit","message_type":"Decision"},
    {"op":"Trace","message":"protocol ToolDefense completed"},
    {"op":"End"}
  ]
}
