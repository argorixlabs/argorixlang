module invalid.policy_external_provider_missing_secret_boundary
provider OpenAI { kind external enabled false dry_run_only true requires feature_flag requires approval }
type Ping { content: string }
capability trace.write { level safe }
policy SecretBoundaryRequired {
    require external_provider_secret_boundary_declared
    on violation { action block trace required }
}
agent Worker {
    receives Ping
    capabilities { trace.write }
    on Ping as ping { trace ping }
}
protocol Flow { User -> Worker: tell Ping }
