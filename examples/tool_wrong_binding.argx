module Argorix.Invalid
capability web.search { level safe }
type UserPrompt { content: string }
type ToolResult { content: string }
tool WebSearch { capability web.search input UserPrompt output ToolResult }
agent Agent {
    receives UserPrompt
    capabilities { web.search }
    tools { WebSearch }
    on UserPrompt as prompt {
        call WebSearch with other
    }
}

