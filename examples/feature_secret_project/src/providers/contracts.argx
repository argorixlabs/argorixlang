module providers.contracts

provider OpenAI {
    kind external
    enabled false
    dry_run_only true
    requires feature_flag
    requires approval
    allowed_targets { GuardModel }
    allowed_capabilities { model.invoke }
}

capability model.invoke { level restricted requires approval }
capability trace.write { level safe }

model GuardModel {
    provider simulated
    capability model.invoke
    input UserPrompt
    output DraftAnswer
}
