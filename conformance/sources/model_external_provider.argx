module Invalid.ModelExternal
provider OpenAI {
    kind external
    enabled false
    dry_run_only true
    requires feature_flag
    requires approval
    allowed_targets { Guard }
    allowed_capabilities { model.invoke }
}
capability model.invoke { level safe }
type Input { value: string }
type Output { value: string }
model Guard { provider OpenAI capability model.invoke input Input output Output }
