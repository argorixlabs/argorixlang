# ---------------------------------------------------------------------------
# Argorix Chatbot Runtime Demo — environment template
#
# Copy this file to `.env.local` (which is git-ignored) and adjust as needed.
# NEVER put a real API key in this file or commit it.
# ---------------------------------------------------------------------------

# Paths to the locally-built Argorix binaries (relative to this demo folder).
# Build them first from the repo root:
#   cargo build --workspace
ARGORIXC_BIN=../../target/debug/argorixc.exe
ARGORIX_VM_BIN=../../target/debug/argorix-vm.exe

# Master switch for the sandboxed external provider call.
# false (default) => plan-only: Argorix validates and PLANS the call, but the
#                    demo NEVER reaches OpenAI. You get a plan + evidence only.
# true            => Argorix validates and PLANS the call, then (and only then)
#                    the server-side adapter performs the sandboxed OpenAI call.
ARGORIX_SANDBOXED_EXTERNAL=false

# OpenAI credentials are read SERVER-SIDE ONLY and are never sent to the browser,
# logged, or written into any trace / report / evidence bundle.
# Argorix only ever sees the reference `env:OPENAI_API_KEY`, never the value.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1
